PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/declic
JWT_SECRET=change_this_secret_key_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d
# En production, définir CORS_ORIGIN avec le domaine autorisé (ex: https://monapp.com)
# En production, si CORS_ORIGIN est absent, toutes les origines sont refusées
CORS_ORIGIN=*
